# FlowMate-Echo 环境配置
# 请将此文件复制为 .env 并填入你的配置

# ==================== 后端服务 ====================
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DEBUG_MODE=true

# ==================== ModelScope ====================
# ModelScope Token (可选，用于模型下载)
MODELSCOPE_TOKEN=

# ==================== DashScope API ====================
# 阿里云 DashScope API Key (用于 Qwen-Max 任务拆解和闲聊) 必须填写
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ==================== 模型配置 ====================
QWEN_MAX_MODEL=qwen-max
QWEN_VL_MODEL=qwen-vl-plus
COSYVOICE_MODEL=iic/CosyVoice-300M-SFT

# ==================== 功能开关 ====================
ENABLE_CAMERA=true
ENABLE_KEYBOARD_HOOK=true

# ==================== Python 依赖版本 (强烈建议遵循这个组合) ====================
# 环境: Anaconda FlowMate_env
# Python: 3.10.19
#
# 核心依赖:
# - mediapipe==0.10.9 (必须此版本，支持 solutions API)
# - protobuf==3.20.3 (必须 <4.0.0)
# - fastapi>=0.128.0
# - uvicorn>=0.40.0
# - opencv-python>=4.13.0
# - dashscope>=1.25.0
# - httpx>=0.28.0
# - python-dotenv>=1.0.0
# - pydantic>=2.0.0
#
# ==================== 安装命令 ====================
# 1. 清理冲突:
#    pip uninstall tensorflow tensorflow-intel mediapipe protobuf -y
#
# 2. 安装 MediaPipe 黄金组合:
#    pip install mediapipe==0.10.9
#    pip install "protobuf<4.0.0"
#
# 3. 安装其他依赖:
#    pip install fastapi uvicorn pydantic python-dotenv httpx dashscope opencv-python numpy pillow
#
# ==================== 注意事项 ====================
# - 不要安装完整的 tensorflow，MediaPipe 0.10.9 自带 TFLite Runtime
# - protobuf 必须锁定在 3.x 版本，否则与 MediaPipe 冲突